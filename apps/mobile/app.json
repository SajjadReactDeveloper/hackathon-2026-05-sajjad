{
  "expo": {
    "name": "FlowChat",
    "slug": "flowchat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "flowchat",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "tech.chaingpt.flowchat"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "tech.chaingpt.flowchat",
      "softwareKeyboardLayoutMode": "pan",
      "navigationBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#00000000"
      },
      "statusBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#00000000",
        "translucent": true
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/splash-icon.png",
          "imageWidth": 120
        }
      ]
    ],
    "typedRoutes": true
  }
}
