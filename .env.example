# ============================================================
# FlowChat — Environment Variables
# Copy to .env.local (web) or .env (api). Never commit secrets.
# ============================================================

# ---- WEB ONLY (apps/web) -----------------------------------

# Supabase — public keys (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# NestJS API base URL seen from the browser
NEXT_PUBLIC_API_URL=https://your-render-service.onrender.com

# Sentry — web DSN (public, injected at build time)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/project-id-web

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- API ONLY (apps/api) -----------------------------------

PORT=3001
NODE_ENV=development

# Postgres — Supabase connection string (Transaction mode for Prisma on serverless)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Supabase service role (server-only — never expose to browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase JWT secret — used by NestJS SupabaseAuthGuard to verify HS256 tokens
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase Storage bucket names
SUPABASE_STORAGE_BUCKET_TTS=tts
SUPABASE_STORAGE_BUCKET_KB=kb
SUPABASE_STORAGE_BUCKET_PRODUCTS=products

# WhatsApp — Meta Cloud API
# accessTokenEnc stored per-workspace in DB (AES-256-GCM), but app secret + enc key are global
WHATSAPP_APP_SECRET=your-meta-app-secret-for-webhook-signature-verify
WHATSAPP_TOKEN_ENC_KEY=your-32-byte-hex-key-for-aes256gcm

# Groq
GROQ_API_KEY=gsk_your_groq_api_key

# OpenAI (Whisper STT + GPT-4o-mini Vision + TTS + text-embedding-3-small)
OPENAI_API_KEY=sk-test-fake-replace-with-real

# ElevenLabs (voice cloning + multilingual TTS fallback)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Sentry — API DSN (server-only)
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/project-id-api
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=flowchat-api
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app,https://*.vercel.app
